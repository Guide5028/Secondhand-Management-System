# =============================================================
# .gitignore — kankrong-frontend
# ✅ = ควร push  ❌ = ไม่ควร push
# =============================================================


# ─────────────────────────────────────────────
# ❌ Dependencies — ไม่ push เพราะไฟล์เยอะมาก (~200MB+)
#    ใครเปิด project ใช้ `npm install` แทน
# ─────────────────────────────────────────────
node_modules/


# ─────────────────────────────────────────────
# ❌ Build output — ไม่ push เพราะ generate จาก src ได้เสมอ
#    ใช้ `npm run build` สร้างใหม่ก่อน deploy
# ─────────────────────────────────────────────
dist/
dist-ssr/


# ─────────────────────────────────────────────
# ❌ Environment / Secret files — ห้าม push เด็ดขาด
#    ถ้าเผลอ push key/password ขึ้น GitHub = รั่วข้อมูล
#    (ตอนนี้ยังไม่มี แต่ป้องกันไว้ก่อน)
# ─────────────────────────────────────────────
.env
.env.local
.env.development
.env.production
.env.staging
.env.*.local
*.pem
*.key
*.secret


# ─────────────────────────────────────────────
# ❌ TypeScript build cache — สร้างใหม่อัตโนมัติ
# ─────────────────────────────────────────────
*.tsbuildinfo
tsconfig.tsbuildinfo


# ─────────────────────────────────────────────
# ❌ Log files — debug เฉพาะเครื่อง ไม่เกี่ยวกับ code
# ─────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*


# ─────────────────────────────────────────────
# ❌ OS system files — Mac/Windows สร้างเอง ไม่มีประโยชน์
# ─────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini


# ─────────────────────────────────────────────
# ❌ Editor / IDE personal config — แต่ละคนตั้งค่าต่างกัน
#    (ยกเว้น extensions.json ที่แนะนำ extension ทีม)
# ─────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp


# ─────────────────────────────────────────────
# ❌ Local dev / Vite cache
# ─────────────────────────────────────────────
*.local
.vite/
.cache/


# ─────────────────────────────────────────────
# ❌ Test / Coverage output
# ─────────────────────────────────────────────
coverage/
.nyc_output/


# =============================================================
# ✅ สิ่งที่ควร push ทั้งหมด (อย่าลบออก)
# =============================================================
# src/                 — code ทั้งหมด
# public/              — static assets (logo, favicon)
# index.html           — entry point
# package.json         — รายชื่อ dependency (ไม่ใช่ตัว library)
# package-lock.json    — lock version ให้ทุกคน install เหมือนกัน
# vite.config.ts       — config build tool
# tailwind.config.js   — config UI framework
# tsconfig*.json       — TypeScript config
# postcss.config.js    — CSS processing
# eslint.config.js     — code style rules
# .gitignore           — ไฟล์นี้เอง
